  "tooltips": [
    {
      "curve": "",
      "endPoint": "Serves as Lieutnant of Kan Garrison."
    },
    {
      "curve": "Heads out to investigate the Hound's attack.\n\nTravels with:\n-",
      "endPoint": "Is recruited by Lorn and sent to market village of Garom."
    },
    {
      "curve": "Travels with:\n-",
      "endPoint": "Meets with Topper."
    },
    {
      "curve": "Travels with Topper through the Imperial Warren to report to Lorn.\n\nTravels with:\nTopper",
      "endPoint": "Is posted in Unta to complete his training under Lorn."
    },
    {
      "curve": "Follows Sorry's trail by boat.\n\nTravels with:\n-",
      "endPoint": ""
    },
    {
      "curve": "Flies to Pale by Quorll, still in pursuit of Sorry.\n\nTravels with:\n-",
      "endPoint": "Is killed by Sorry, resurrected by Oponn outside Hood's Gate and goes into hiding in Tattersail's rooms after protecting her from the Hound Gear."
    },
    {
      "curve": "Follows Tattersail who has left to warn the Bridgeburners.\n\nTravels with:\nToc",
      "endPoint": "Discovers the location of Tattersail and Bellurdan's fight and thinks Lorn is responsible."
    },
    {
      "curve": "Finds Lorn's tracks and follows her to take revenge.\n\nTravels with:\nToc",
      "endPoint": "Is ambushed by Hairlock and the both of them are ambushed by two of the Hounds who are killed by Anomander Rake. Paran touches the blood of on of the dead hounds."
    },
    {
      "curve": "Is dragged into Dragnipur where he uses Oponn to free the hounds and himself.\n\nTravels with:\n-",
      "endPoint": "Returns to the Rhivi plain."
    },
    {
      "curve": "Continues to follow Lorn.\n\nTravels with:\n-",
      "endPoint": "Meets Coll."
    },
    {
      "curve": "Heads into Darujhistan.\n\nTravels with:\nColl",
      "endPoint": "Eventually finds Lorn who is mortally wounded and dies in his arms."
    },
    {
      "curve": "Carries Lorn's body to bury her while on the way to his next mission.\n\nTravels with:\nThe Bridgeburners",
      "endPoint": "Buries Lorn and meets the Moranth who pick him and the Bridgeburners up."
    },
    {
      "curve": "Is carried by the Moranth.\n\nTravels with:\nThe Bridgeburners",
      "endPoint": "Collects taxes from travelers who pass through on their way to Darujhistan to raise war funds."
    },
    {
      "curve": "Moves to Pale by Quorl to join Caladan Brood's forces against the Pannion Domain.\n\nTravels with:\nThe Bridgeburners",
      "endPoint": ""
    },
    {
      "curve": "Heads out into Caladan Brood's army's camp for tactical meetings.\n\nTravels with:\nThe Bridgeburners, Dujek",
      "endPoint": "Meets with Caladan Brood, Anomander Rake, Dujek and the other important leaders for a tactical meeting."
    },
    {
      "curve": "Is teleported into the Finnest House in Darujhistan by a table. He also explores some Holds from there, including the empty Beast Hold.\n\nTravels with:\n-",
      "endPoint": "Returns to the camp."
    },
    {
      "curve": "Flies to the White Faced Barghast camp to allow Trott to take leadership of the clan and get them to help in the war.\n\nTravels with:\nThe Bridgeburners",
      "endPoint": "Trott wins the duel and with it leadership over the White Faced Barghast."
    },
    {
      "curve": "Moves to Capustan to save the city with the Bridgeburners and Barghast while the slower main armies are still traveling towards Coral.\n\nTravels with:\nThe Bridgeburners, The White Faced Barghast",
      "endPoint": "Fights in the city to stop the Pannion forces from sieging it and eventually rejoins with Caladan Brood's forces."
    },
    {
      "curve": "Marches towards Settar to retake the city, while Caladan Brood's forces take Lest at the same time.\n\nTravels with:\nThe Bridgeburners, The White Faced Barghast, Kruppe",
      "endPoint": "Finds Settar entirely void of life."
    },
    {
      "curve": "Quickly moves towards Coral by Quorl to attack it before Caladan's forces arrive there and claim it for the Malazan empire.\n\nTravels with:\nThe Bridgeburners, The White Faced Barghast, Kruppe",
      "endPoint": "Makes camp in front of Coral."
    },
    {
      "curve": "Tries to contact Anomander Rake but is instead dragged into Dragnipur's Warren where he speaks to Draconus.\n\nTravels with:\n-",
      "endPoint": "Falls unconscious and awakens back in the Bridgeburner's camp."
    },
    {
      "curve": "Enters Coral by Quorl.\n\nTravels with:\nThe Bridgeburners, The White Faced Barghast",
      "endPoint": "Uses the attack on the city to find the Pannion Seer."
    },
    {
      "curve": "Travels to Morn through a Warren to free the Seer's sister.\n\nTravels with:\nThe Pannion Seer, Quick Ben, Kilava Onass",
      "endPoint": "Frees the Seer's sister."
    },
    {
      "curve": "Takes the Seer and his sister to Burn's flesh to slow the Chained God's corruption.\n\nTravels with:\nQuick Ben, The Pannion Seer and his sister",
      "endPoint": ""
    },
    {
      "curve": "Returns to Coral to reunite with the Bridgeburners.\n\nTravels with:\nQuick Ben",
      "endPoint": "Meets the few Bridgeburners remaining after the attack."
    },
    {
      "curve": "Accompanies the remaining Bridgeburners on their way to Darujhistan where they plan to retire.\n\nTravels with:\nThe Bridgeburners",
      "endPoint": "Stays in Darujhistan and the local Azath house for a while."
    },
    {
      "curve": "Travels to the Raraku by boat.\n\nTravels with:\n-",
      "endPoint": "Takes Apsalar onto his ship."
    },
    {
      "curve": "Travels to the Raraku by boat.\n\nTravels with:\nApsalar",
      "endPoint": "Parts ways with Apsalar."
    },
    {
      "curve": "Travels to the Raraku.\n\nTravels with:\nGanath",
      "endPoint": "Raises the undead of the Raraku to ask the Bridgeburners for help with releasing the Deragoth. Also meets the members of the Trygalle Guild who he hired to accompany him."
    },
    {
      "curve": "Travels through Verdith'anath into the Nascent.\n\nTravels with:\nHedge, The Trygalle Trade Guild, Ganath",
      "endPoint": "Frees the remaining Deragoth."
    },
    {
      "curve": "Escapes through the Warren of Death and Omtose Phellak.\n\nTravels with:\nThe Trygalle Trade Guild, Ganath",
      "endPoint": "Leaves the Warrens and find Dujek's host in a bad condition due to Poliel's pest."
    },
    {
      "curve": "Leaves to deal with Poliel's pest.\n\nTravels with:\nNoto Boil",
      "endPoint": "Defeats Poliel."
    },
    {
      "curve": "Returns to the army's camp.\n\nTravels with:\nNoto Boil",
      "endPoint": "Takes command over Dujek's host after he passed away."
    },
    {
      "curve": "Takes the army east since he senses a force in that direction.\n\nTravels with:\nDujek's host",
      "endPoint": "Sees the imminent impact of the Jade Meteors."
    },
    {
      "curve": "Enters the Warren of Death to make a deal with Hood to stop the Jade Meteors.",
      "endPoint": "Returns from the Warren of Death."
    },
    {
      "curve": "Continues to lead the army east.\n\nTravels with:\nDujek's host",
      "endPoint": "Is approached by Mathok and his riders who surrender themselves to him. He accepts them into his forces."
    },
    {
      "curve": "Marches his army towards Aren.\n\nTravels with:\nDujek's host, Mathok and his riders",
      "endPoint": ""
    },
    {
      "curve": "",
      "endPoint": "Hold North Citadel against the Assail forces."
    },
    {
      "curve": "Leads his host in an offense against the Assail.\n\nTravels with:\nHis Host",
      "endPoint": "Breeches the Verender defenses."
    },
    {
      "curve": "Marches towards the Bonehunters' last stand against the Assail forces to help them.\n\nTravels with:\nHis host",
      "endPoint": "Rescues the Bonehunters."
    },
    {
      "curve": "",
      "endPoint": "Attends Gelser and Stormies funeral."
    }
  ]
}