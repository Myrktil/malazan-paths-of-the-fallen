  "tooltips": [
    {
      "curve": "Escorts the merchant Keruli.\n\nTravels with:\nStonny, Harlow",
      "endPoint": "Meets Hetan and Cafal."
    },
    {
      "curve": "Escorts the merchant Keruli.\n\nTravels with:\nStonny, Harlow, Hetan, Cafal",
      "endPoint": "Is attacked by undead K'Chain Che Malle. Harllo dies before before Keruli can save them. After the fight he meets Itkovian."
    },
    {
      "curve": "Is escorted to Capustan by Itkovian.\n\nTravels with:\nStonny, Hetan, Cafal, Itkovian",
      "endPoint": "Stays in Capustan until the Pannion Invasion is defended."
    },
    {
      "curve": "Joins Caladan Brood's main forces on their campaign to free the other cities as Trake's Mortal Sword.\n\nTravels with: \nStonny, Caladan Brood's forces",
      "endPoint": "Fights in the battle for Coral."
    },
    {
      "curve": "Returns to Darujhistan to resume his previous life.\n\nTravels with:\nStonny",
      "endPoint": "Stays in Darujhistan for a while."
    },
    {
      "curve": "Serves as a caravan guard on a trip to buy Kelyk from Bastion.\n\nTravels with:\n-",
      "endPoint": "Joins the Trygalle Trade Guild as a shareholder."
    },
    {
      "curve": "Escorts Mappo to Lether through Hood's Warren.\n\nTravels with:\nOther Trygalle shareholders, Mappo",
      "endPoint": "Is overwhelmed by the dead marching somewhere and escapes to Mael's Warren through a portal opened by his partie's mage."
    },
    {
      "curve": "Continues his journey to Lether through Mael's Warren.\n\nTravels with:\nOther Trygalle Shareholders, Mappo, Cartographer",
      "endPoint": "Leaves the Warren due to a strong storm."
    },
    {
      "curve": "Flees from a Jaghut dispute through a portal opened by Cartographer.\n\nTravels with:\nOther Trygalle shareholders, Mappo, Cartographer",
      "endPoint": "Finds himself in the Warren of Dragnipur where Hood's forces fight against the forces of Chaos. Leaves with his caravan after being dismissed by Hood."
    },
    {
      "curve": "Continues to escort Mappo to Lether through the Warrens.\n\nTravels with:\nOther Trygalle Shareholders, Mappo, Cartographer",
      "endPoint": "Leaves the Warrens."
    },
    {
      "curve": "Continues to escort Mappo.\n\nTravels with:\nOther Trygalle shareholders, Mappo",
      "endPoint": "Is attacked by a Shi'gal assassin. His carriage is destroyed."
    },
    {
      "curve": "Continues to escort Mappo.\n\nTravels with:\nOther Trygalle shareholders, Mappo",
      "endPoint": "Leaves the group to continue on alone."
    },
    {
      "curve": "Loses himself in his animal form while wandering through the Warrens.\n\nTravels with:\n-",
      "endPoint": "Comes upon the gate to Starvald Demelain and dies trying to stop Kilava from opening it."
    }
  ]
}