  "tooltips": [
    {
      "curve": "",
      "endPoint": "Saves Lorn from Barghast."
    },
    {
      "curve": "Follows Lorn to Raest's Jaghut tomb.\n\nTravels with:\n-",
      "endPoint": "Enters Raest's Tomb alongside Lorn. He stays there after Lorn leaves saying he will wait to witness."
    },
    {
      "curve": "",
      "endPoint": "Enters Kruppe's dream warren to attacks Raest and help Paran fight the Azath."
    },
    {
      "curve": "Travels with:\n-",
      "endPoint": "Meets Lady Envy and Toc."
    },
    {
      "curve": "Follows the group towards the Pannion Domain.\n\nTravels with:\nToc, Lady Envy",
      "endPoint": "Decides to follow Lady Envy in her war against the Pannion Domain while Toc leaves."
    },
    {
      "curve": "Fights his way towards Coral.\n\nTravels with:\nLady Envy",
      "endPoint": "Takes the city."
    },
    {
      "curve": "Cotinues his advance towards Coral leaving Lady Envy behind.\n\nTravels with:\n-",
      "endPoint": "Enters the keep and frees Toc."
    },
    {
      "curve": "Enters the Mhybe's Dream Warren where he meets with Silverfox to demand she free the T'lan Imass and to give up his title of First Sword of the T'lan Imass.\n\nTravels with:\n-",
      "endPoint": "Is reborn as flesh and blood."
    },
    {
      "curve": "Travels towards the Barghast range to make a new sword.\n\nTravels with:\nKilava, Hetan, Cafal",
      "endPoint": ""
    },
    {
      "curve": "Leads the Barghast on their search for a holy war.\n\nTravels with:\nThe Barghast",
      "endPoint": "Makes camp."
    },
    {
      "curve": "Leads a troop of Barghast to battle against the K'Chain Che'Malle.\n\nTravels with:\n100 Barghast",
      "endPoint": "Kills himself to protect the Barghast who followed him."
    },
    {
      "curve": "Wanders through a Warren to find the other fallen T'lan Imass.\n\nTravels with:\n-",
      "endPoint": "Is forced to return by Toc, who is controlled by Olar Ethil."
    },
    {
      "curve": "Searches for the other T'lan Imass who were summoned nearby.\n\nTravels with:\n-",
      "endPoint": "Takes leadership of the summoned T'lan Imass as their First Sword."
    },
    {
      "curve": "Leads his T'lan Imass warriors to the camp of the Senan who are fleeing from the Akrynnai.\n\nTravels with:\nThe T'lan Imass warriors",
      "endPoint": "Murders everyone in the Senan camp."
