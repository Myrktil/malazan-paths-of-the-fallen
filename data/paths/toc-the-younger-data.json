  "tooltips": [
    {
      "curve": "",
      "endPoint": "Takes part in the siege of Pale, losing his eye in the process."
    },
    {
      "curve": "Heads out to meet Lorn who is on her way to Pale.\n\nTravels with:\n-",
      "endPoint": "Saves Lorn from a Barghast attack."
    },
    {
      "curve": "Returns to Pale.\n\nTravels with:\nLorn",
      "endPoint": ""
    },
    {
      "curve": "Joins Paran on his search for Tattersail.\n\nTravels with:\nParan",
      "endPoint": "He and Paran find the location of Tattersail and Bellurdan's fight."
    },
    {
      "curve": "Continues to follow Paran who is now hunting Lorn for revenge.\n\nTravels with:\nParan",
      "endPoint": "Is ambushed by Hairlock who throws him into the Warren of Chaos."
    },
    {
      "curve": "Is unconsciuos in the Warren of Chaos.\n\nTravels with:\n-",
      "endPoint": "Is approached by Togg, wakes up in Morn and meets Lady Envy and Tool."
    },
    {
      "curve": "Travels into the Pannion Domain to reunite with the Malazans.\n\nTravles with: \nTool, Lady Envy",
      "endPoint": "Leaves Tool and Lady Envy to travel alone as part of the Tenescrowri because he fears for his survival if he were to stay with them."
    },
    {
      "curve": "Hides among the Tenescrowri to reach the Malazan forces.\n\nTravels with:\nThe Tenescrowri ",
      "endPoint": "Meets the Seer who sees through his disguise and imprisons him with the K'Chain Che Malle matron."
    },
    {
      "curve": "Is taken by the Seer, who is fleeing from Tool, to Coral through Omtose Phellak.\n\nTravels with: \nThe Pannion Seer",
      "endPoint": "Is saved by Toc but kills himself to free Togg's soul within him. Is then reborn as Toc-Anaster."
    },
    {
      "curve": "Joins the Grey Swords as Togg and Fanderay's Mortal Sword.\n\nTravels with:\nThe Grey Swords",
      "endPoint": ""
    },
    {
      "curve": "Follows Tool and his Barghast.\n\nTravels with:\nThe Gray Swords",
      "endPoint": "Is betrayed by the Ahl, who we fought for, and loses his Grey Swords in a fight against the Letherii."
    },
    {
      "curve": "Stays with the Ahl during Redmask's war against the Letherii.\n\nTravels with:\nThe Ahl",
      "endPoint": "Dies while protecting the last Ahl children against the Letherii."
    },
    {
      "curve": "Serves as a commander in Hood's forces.\n\nTravels with:\nWiskeyjack, Brukhalian",
      "endPoint": "Fights in Dragnipur against the forces of Chaos."
    },
    {
      "curve": "?",
      "endPoint": "Is forced to keep Tool from returning to the Imass sanctum by Olar Ethil."
    },
    {
      "curve": "?",
      "endPoint": "Rescues Stavi, Storii and Absi from the fights in the Barghast camp."
    },
    {
      "curve": "Escorts Stavi, Storii and Absi to safety.\n\nTravels with:\nStavi, Storii, Absi, Setoc",
      "endPoint": "Sends the children and Setoc east to follow the Trygalle carriage's tracks and leaves the group."
    },
    {
      "curve": "?",
      "endPoint": "Appears on a hill to watch Stavi, Storii and Absi among their new companions and leaves again."
    },
    {
      "curve": "",
      "endPoint": "Recovers Hetan's corpse."
    },
    {
      "curve": "",
      "endPoint": "Meets and joins the Bridgeburner's ghosts."
    },
    {
      "curve": "",
      "endPoint": "Joins the fight against the Assail with the Bridgeburners."
    },
    {
      "curve": "",
      "endPoint": "Watches Tool reunite with his family before becoming one of the Bridgeburners and leaving with them."
    }
  ]
