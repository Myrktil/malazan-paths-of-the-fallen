  "tooltips": [
    {
      "curve": "",
      "endPoint": "Stationed at a fishing village."
    },
    {
      "curve": "Flees on a ship from the uprising locals with Kulp on their ship.\n\nTravels with:\nStormy, Truth, Kulp",
      "endPoint": "Is convinced by Kulp to go to Otataral Desert to pick up Heboric as he's a priest of Fener.\n\nTravels with:\nStormy, Truth, Kulp"
    },
    {
      "curve": "Travels to the pickup spot on the Otataral Desert's cost.\n\nTravels with:\nStormy, Truth, Kulp",
      "endPoint": "Picks up Heboric, Felisin and Baudin."
    },
    {
      "curve": "Returns to Seven Cities mainland.\n\nTravels with:\nStormy, Truth, Kulp, Felisin, Heboric, Baudin",
      "endPoint": "The entire ship is dragged into flooded Kurald Ehmurlahn by a a mage who has gone insane from the exposure to Otataral in the mines."
    },
    {
      "curve": "Travels with:\nStormy, Truth, Kulp, Felisin, Heboric, Baudin",
      "endPoint": "Finds a new boat in the flooded warren, the Silanda."
    },
    {
      "curve": "Travels through the flooded warren on the Silanda.\n\nTravels with:\nStormy, Truth, Kulp, Felisin, Heboric, Baudin",
      "endPoint": "Encounters a Soletaken undead dragon. Kulp uses the chance to pull them into a new Warren in the dragon's wake."
    },
    {
      "curve": "Stays on the Silanda and travels through the new Warren while Felisin, Kulp, Baudin and Heboric jump off the ship to escape the Warren's fires.\n\nTravels with:\nStormy, Truth",
      "endPoint": "Somehow leaves the Warren. Doesn't enter Ubaryd since it has already fallen to the rebels."
    },
    {
      "curve": "  Travels with:\nStormy, Truth",
      "endPoint": "While resting on shore he meets Duiker and later Coltaine. Coltaine sends him, Stormy and Truth ahead to Aren with his wounded soldiers to dislodge Pormqual to come aid Coltaine."
    },
    {
      "curve": "Travels to Aren on the Silanda.\n\nTravels with:\nStormy, Truth",
      "endPoint": "Arrives in Aren too late."
    },
    {
      "curve": "Travels up the Aren way to search for Duiker among the crucified soldiers.\n\nTravels with:\nStormy, Truth",
      "endPoint": "Does not find Duiker."
    },
    {
      "curve": "Returns to Aren.\n\nTravels with:\nGesler, Truth",
      "endPoint": "Joins the Bonehunters."
    },
    {
      "curve": "Marches into the Raraku to defeat Sha'ik.\n\nTravels with:\nThe Bonehunters",
      "endPoint": "Defeats Sha'ik."
    },
    {
      "curve": "Chases Leoman and his rebels with the Bonehunters.\n\nTravels with:\nThe Bonehunters",
      "endPoint": "Fights in Y'Gathan and is left behind beneath the city."
    },
    {
      "curve": "Catches up to the Bonehunter main forces.\n\nTravels with:\nFiddler's squad, Apsalar, Quick Ben, Kalam, Faradan Sort, Stormy",
      "endPoint": "Rejoins the Bonehunters."
    },
    {
      "curve": "Sails with the Bonehunters to Malaz.\n\nTravels with:\nThe Bonehunters",
      "endPoint": "Meets the Verender who join the Bonehunters."
    },
    {
      "curve": "Is teleported through the Warren of Togg and Fanderay by the Verender.\n\nTravels with:\nThe Bonehunters, The Verender",
      "endPoint": "Leaves the Warren."
    },
    {
      "curve": "Follows the Bonehunters to Malaz.\n\nTravels with:\nThe Bonehunters, The Verender",
      "endPoint": "Defends the Bonehunter fleet against the angry mob."
    },
    {
      "curve": "Leaves with the now outcast Bonehunters to Letheras to take revenge on the Edur.\n\nTravels with:\nThe Bonehunters, The Verender",
      "endPoint": "Takes over the Fort which is then established as the Bonehunters base."
    },
    {
      "curve": "Is send to scout and figure out the current situation in Lether.\n\nTravels with:\nHis squad",
      "endPoint": "Joins up with Fiddlers squad."
    },
    {
      "curve": "Advances further into Lether.\n\nTravels with:\nHis squad, Fiddler's squad",
      "endPoint": "Reunites with the other marine squads."
    },
    {
      "curve": "Advances into Letheras.\n\nTravels with: \nThe marines",
      "endPoint": "Takes over Letheras with the Bonehunter main forces who arrived through the river."
    },
    {
      "curve": "Marches towards Kolanse.\n\nTravels with:\nThe Bonehunters, Brys and his troops",
      "endPoint": "Is abducted by the Shi'gal.\n\nTravels with:\nStormy"
    },
    {
      "curve": "Is carried by the Shi'gal.\n\nTravles with:\nStormy",
      "endPoint": "Becomes the K'Chain Che'Malle's Mortal Sword."
    },
    {
      "curve": "Leads the K'Chain Che'Malle into battle against the K'Chain Nah'ruk.\n\nTravels with:\nStormy, Kalyth, The K'Chain Che'Malle",
      "endPoint": "Defeats the Nah'ruk."
    },
    {
      "curve": "Tries to catch up to the Bonehunter's allies while Stormy looks for signs of the Bonehunters.\n\nTravels with:\nKaylinh, The K'Chain Che'Malle",
      "endPoint": "Stormy returns."
    },
    {
      "curve": "Tries to catch up to the Bonehunter's allies.\n\nTravels with:\nStormy, Kaylinh, The K'Chain Che'Malle",
      "endPoint": "Catches up to Brys and his host and starts to travel alongside them."
    },
    {
      "curve": "Marches around the Glass Desert to get to Kolanse.\n\nTravels with:\nBrys and his forces, Stormy, Kaylinh, The K'Chain Che'Malle",
      "endPoint": "Joins forces with the Evertine Legion forces who has been left behind by the Verender."
    },
    {
      "curve": "Marches around the Glass Desert to get to Kolanse.\n\nTravels with:\nBrys and his forces, The Evertine Legion, Stormy, Kaylinh, The K'Chain Che'Malle",
      "endPoint": "Leaves Brys and Abrastal to mount a direct attack on the Spire."
    },
    {
      "curve": "Travels to the Spire to mount a direct attack.\n\nTravels with:\nStormy, Kaylinh, The K'Chain Che'Malle",
      "endPoint": "Fights with the T'Lan Imass, Jaghut and others against the Assail forces."
    },
    {
      "curve": "Retreats from the fight.\n\nTravels with:\nStormy, Kaylinh, The K'Chain Che'Malle",
      "endPoint": ""
    },
    {
      "curve": "Follows Sinn to stop her from taking the Crippled God's heart.\n\nTravels with:\nStormy",
      "endPoint": "Is killed by Sister Reverance while protecting the Crippled God's heart."
    }
  ]
