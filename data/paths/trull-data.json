  "tooltips": [
    {
      "curve": "",
      "endPoint": "Is hunting seals."
    },
    {
      "curve": "Returns to the Edur main village.\n\nTravels with:\n-",
      "endPoint": "Informs Hannan Mosag about the illegal seal hunting by the Letherii."
    },
    {
      "curve": "Joins Hannan Mosag who sails out to punish the Letherii for the treaty infringement.\n\nTravels with:\nFear",
      "endPoint": "Hannan Mosag kills the Letherii using magic."
    },
    {
      "curve": "Returns to the Edur main village.",
      "endPoint": "Is send on a mission by Hannan Mosag to retrieve a weapon he saw in one of his vision."
    },
    {
      "curve": "Ventures into the Jheck lands to retrieve Hannan Mosag's weapon.\n\nTravels with:\nFear, Rulad, Binadas",
      "endPoint": "Retrieves the weapon and is attacked by the Jheck. Rhulad dies."
    },
    {
      "curve": "Retreats back to the village while being attacked by the Jheck.\n\nTravels with: \nFear, Binadas",
      "endPoint": "Is split from the group."
    },
    {
      "curve": "Fights his way back alone.\n\nTravels with: \n-",
      "endPoint": "Rejoins with his brothers."
    },
    {
      "curve": "Returns home.\n\nTravels with:\nFear, Binadas",
      "endPoint": "Rhulad is revived, becomes the Edur leader and starts a war against the Letherii."
    },
    {
      "curve": "Marches with the Edur land forces.\n\nTravels with:\nForcht, Binadas",
      "endPoint": "The armies split again, with Binadas and his father taking the cities to the east while Fear and Trull march south to meet with Rhulad's sea forces."
    },
    {
      "curve": "Travels with Fear and his forces.\n\nTravels with:\nFear",
      "endPoint": "Reunites with Rhulad and his part of the Edur who attacked the Letherii from the sea."
    },
    {
      "curve": "Investigates rumors of a strong demon freed nearby by the Letherii.\n\nTravels with:\nRhulad, Fear",
      "endPoint": "Fights the demon, who turns out to be the Forkrul Assail Serenity."
    },
    {
      "curve": "Catches back up to the Edur army.\n\nTravels with:\nFear, Rhulad",
      "endPoint": "Catches up to the Edur army and rejoins with the forces of Binadas and his father."
    },
    {
      "curve": "Marches into Letheras.\n\nTravels with:\nFear, Rhulad, Binadas",
      "endPoint": "Stays in the occupied city until he is shorn by Rhulad."
    },
    {
      "curve": "Is taken to the Nascent by Rhulad to drown there.\n\nTravels with:\nRhulad",
      "endPoint": "Is saved by Onrack."
    },
    {
      "curve": "Follows Onrack on his search for the Unbound.\n\nTravels with: \nOnrack",
      "endPoint": "Meets and fights a group of Tiste Liosan. Is saved by Monok Ochem and his T'lan Imass who were looking for the Unbound with Onrack. Forms an alliance with the Liosan and Imass to create a portal out of the Nascent."
    },
    {
      "curve": "Continues to hunt the Unbound in an attempt to appease Monok Ochem and his T'lan Imass and stop them from destroying the broken Onrack.\n\nTravels with:\nOnrack",
      "endPoint": "Teams up with Monock Ochem and his T'lan Imass to stop the Unbound from reaching the First Throne."
    },
    {
      "curve": "Is teleported through Omtose Phellak and Tellan to the First Throne by Monok Ochem.\n\nTravels with:\nOnrack",
      "endPoint": "Protects the First Throne with Minala and her children."
