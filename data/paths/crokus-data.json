  "tooltips": [
    {
      "curve": "",
      "endPoint": "Lives in Darujhistan."
    },
    {
      "curve": "Accompanies Kruppe on his journey into the Gadrobi Hills. \n\nTravels with:\nKruppe, Coll, Murillio",
      "endPoint": "They are attacked and defeated by Lorn. They also meet a confused Apsalar who has just been left by Cotillion."
    },
    {
      "curve": "Takes Apsalar to Darujhistan to get Mammot to help her recover from being posessed by Cotillion.\n\nTravels with:\nApsalar",
      "endPoint": "Get's involved in the events sourrounding Lady Simtal's Fete."
    },
    {
      "curve": "Accompanies Apsalar who is taken back to Itko Kan by Fiddler and Kalam.\n\nTravels with:\nApsalar, Fiddler, Kalam",
      "endPoint": "Instead of going to Quon Tali directly, Fiddler and Kalam decide to use the Azath house Tremorlor to get into Malaz unseen which would help them with their secret goal of killing empress Laseen."
    },
    {
      "curve": "Follows Fiddler and Kalam who try to find Tremorlor.\n\nTravels with:\nApsalar, Fiddler, Kalam",
      "endPoint": "Kalam splits from the group leaving him alone with Apsalar and Fiddler."
    },
    {
      "curve": "Follows Fiddler who continues to search for Tremorlor under the guise of an outcast Gral who protects Apsalar and him who pretend to be a newly wed couple.\n\nTravels with:\nApsalar, Fiddler",
      "endPoint": "Apsalar thinks they are being pursued. Fiddler thinks it's the Gral who are searching for him due to his disguise."
    },
    {
      "curve": "Head's into the whirlwind to escape the Gral.\n\nTravels with:\nApsalar, Fiddler",
      "endPoint": "Meets Mappo and Icarium who were send to find him, Apsalar and Fiddler by Iskaral Pust."
    },
    {
      "curve": "Is taken by to Tesem by Mappo and Icarium.\n\nTravels with:\nApsalar, Fiddler, Icarium, Mappo",
      "endPoint": "Stays in Tesem for a while."
    },
    {
      "curve": "Follows Apsalar who is following her father into the whirlwind.\n\nTravels with:\nFiddler, Icarium, Mappo",
      "endPoint": "Enters the Azath Warren of Tremorlor."
    },
    {
      "curve": "Travels through the Azath's paths.\n\nTravels with:\nApsalar, Fiddler",
      "endPoint": "Meets Shadowthrone in the Azath house."
    },
    {
      "curve": "Is teleported with Apsalar back to her home village by Shadowthrone using the Warren of Shadow.\n\nTravels with:\nApsalar",
      "endPoint": "Takes on a mission for Cotillion."
    },
    {
      "curve": "Sails to Drift Avalii on a mission for Cotillion.\n\nTravels with:\nApsalar",
      "endPoint": "Defends the Throne of Shadow from the Tiste Edur."
    },
    {
      "curve": "Is teleported away by Cotillion after completing his mission.\n\nTravels with:\nApsalar",
      "endPoint": "Stays in Tesem until Apsalar suddenly disappears. He then takes on the task of protecting Felisin II on her journey."
    },
    {
      "curve": "Returns Heboric to the Otataral isle.\n\nTravels with:\nFelisin II, Heboric, Scillara, Greyfrog",
      "endPoint": "Meets the Seguleh Second, who tells him of impending danger in Darujhistan, convincing him to return there as soon as possible."
    },
    {
      "curve": "Returns to Darujhistan.\n\nTravels with:\nFelisin II, Heboric, Scillara, Greyfrog",
      "endPoint": "Is attacked and killed by the Unbound. Is revived by Loric."
    },
    {
      "curve": "Returns to Darujhistan.\n\nTravels with:\nScillara, Barathol, Chaur",
      "endPoint": "Get's caught in the Jade Meteor storm. His boat breaks but he is saved by Spite, who happened to be nearby, onto her boat."
    },
    {
      "curve": "Returns to Darujhistan.\n\nTravels with:\nBarathol, Scillara, Mappo, Iskaral Pust, Morgora, Spite",
      "endPoint": "Stays in Darujhistan for a while."
    },
    {
      "curve": "Visits Gorlas Vidikas' mines to avenge Murillio's death.\n\nTravels with:\n-",
      "endPoint": "Accidentally ends up among the defenders of Dragnipur against the Hounds of Light."
    },
    {
      "curve": "Leaves the city with Spite.\n\nTravels with:\nSpite",
      "endPoint": "Meets Apsalar."
    }
  ]
}