  "tooltips": [
    {
      "curve": "",
      "endPoint": "Visits the Tanno Spiritwalkers with Mappo."
    },
    {
      "curve": "Follows Mappo who searches of the Path of Hands.\n\nTravels with:\nMappo",
      "endPoint": "Seeks refuge in Tesem after being attacked by Leopard Diivers."
    },
    {
      "curve": "Is send into the Raraku by Iskaral Pust.\n\nTravels with:\nMappo",
      "endPoint": "Finds Fiddler, Apsalar and Crokus on their search for Tremorlor."
    },
    {
      "curve": "Returns to the temple.\n\nTravels with:\nMappo, Fiddler, Apsalar, Crokus",
      "endPoint": ""
    },
    {
      "curve": "Follows Apsalar, who is chasing her father, into the Whirlwind.\n\nTravels with:\nMappo, Fiddler, Crokus",
      "endPoint": "Enters Tremorlor."
    },
    {
      "curve": "Travels through the paths of the Azath.\n\nTravels with:\nMappo",
      "endPoint": "Falls unconcious."
    },
    {
      "curve": "Is carried by Mappo to Aren Way.\n\nTravels with:\nMappo",
      "endPoint": "Wakes up again."
    },
    {
      "curve": "Wanders around aimlessly.\n\nTravels with:\nMappo",
      "endPoint": "Meets Karsa."
    },
    {
      "curve": "Searches for the ruins of Trebur.\n\nTravels with:\nMappo",
      "endPoint": "Is attacked by Dejim Nebrahl and seperated from Mappo. Taralack Veed becomes his new protector."
    },
    {
      "curve": "Follows Taralack Veed.\n\nTravels with:\nTaralack Veed",
      "endPoint": "Is persuaded by Taralack Veed to join the Edur fleet searching for fighters for Rhulad."
    },
    {
      "curve": "Travels with the Edur to Letheras.\n\nTravels with:\nThe Edur, Taralack Veed",
      "endPoint": "The Edur want to test him."
    },
    {
      "curve": "Is teleported by the Edur to help them take over the Throne of Shadow.\n\nTravels with:\nSome Edur, Taralack Veed",
      "endPoint": "Finds the Throne of Shadow to be in ruin."
    },
    {
      "curve": "Is taken to the First Throne by the enraged Edur instead.\n\nTravels with:\nSome Edur, Taralack Veed",
      "endPoint": "Is defeated by Quick Ben and Trull."
    },
    {
      "curve": "Is taken back to the Edur fleet by the Edur.\n\nTravels with:\nSome Edur, Taralack Veed",
      "endPoint": "Rejoins the Edur fleet."
    },
    {
      "curve": "Travels with the Edur to Letheras.\n\nTravels with:\nThe Edur, Taralack Veed",
      "endPoint": "Activates the contraption in Letheras to create new Warrens but looses himself in the process."
    },
    {
      "curve": "Wanders around imagining himself to be a group of travelers.\n\nTravels with:\n-",
      "endPoint": "Regains his sense of self and takes control over the reactivated Che'Malle skykeep."
    },
    {
      "curve": "Flies with Kalse towards the K'Chain Naruk.\n\nTravels with: \n-",
      "endPoint": "Seals the K'Chain Naruk's portal into Wu."
    },
    {
      "curve": "",
      "endPoint": "Has been taken by Sister Calm who intends to use him as a weapon. She is killed by Ublala."
    },
    {
      "curve": "Continues the search for his past.\n\nTravels with:\nUblala",
      "endPoint": ""
    }
  ]
}