  "tooltips": [
    {
      "curve": "",
      "endPoint": "Stationed in Pale as part of mage cadre 3."
    },
    {
      "curve": "Travels in the High Thyr Warren trying to reach the Bridgeburners in Darujhistan and warn them of the Empress' betrayal.\n\nTravels with:\n-",
      "endPoint": "Is forced out of the Warren by Tool's Tellan field."
    },
    {
      "curve": "Travels with:\n-",
      "endPoint": "Meets Bellurdan."
    },
    {
      "curve": "Her soul, now merged with Nightchills body, wanders through the Rhivi plain.\n\nTravels with:\n-",
      "endPoint": "Appears in Kruppe's dream where she is reborn as a Rhivi "
    },
    {
      "curve": "Appears in Kruppe's dream where she is reborn as a Rhivi child.\n\nTravels with:\nKruppe",
      "endPoint": "She and her new mother travel as part of the Rhivi among Caladan Brood's troops."
    },
    {
      "curve": "Travels with:\n-",
      "endPoint": "Meets Paran."
    },
    {
      "curve": "Heads back towards Caldan Brood's troops and the Rhivi.\n\nTravels with:\n-",
      "endPoint": "Takes part in the tactical meetings between Caldan Brood's, Dujek's and Anomander Rake's forces."
    },
    {
      "curve": "Stays with her mother and the Rhivi, who are part of the alliances forces.\n\nTravels with:\nThe alliance's main forces.",
      "endPoint": ""
    },
    {
      "curve": "Leaves to attend the Second Gathering.\n\nTravels with: \n-",
      "endPoint": "Attends the Second Gathering."
    },
    {
      "curve": "Returns to Capustan.\n\nTravels with:\n-",
      "endPoint": "Attend's the parley after Capustan has been saved."
    },
    {
      "curve": "Meet's Paran and travels with the Bridgeburners.\n\nTravels with:\nThe Bridgeburners, Paran",
      "endPoint": "Leaves the Bridgeburners."
    },
    {
      "curve": "Travels with:\nThe T'lan Imass",
      "endPoint": "Flees once she sees that she is loosing the T'lan Imass to Itkovian."
    },
    {
      "curve": "Travels through Tellan into the Mhybe's Dream World and back into Tellan.\n\nTravels with:\n-",
      "endPoint": "Meets with the T'lan Imass."
    },
    {
      "curve": "Travels to the continent of Assail to help the trapped T'lan Imass.\n\nTravels with:\nThe T'lan Imass",
      "endPoint": ""
    }
  ]
