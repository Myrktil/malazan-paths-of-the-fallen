  "tooltips": [
    {
      "curve": "",
      "endPoint": "Lives there until the Cull of Nobility."
    },
    {
      "curve": "Is put on a slave ship to be send to the Otataral mines with the other members of nobility.\n\nTravels with:\nHeboric, Baudin",
      "endPoint": "Works in Skullcup until the rebellion."
    },
    {
      "curve": "Heboric and Baudin help her escape and escort her to the cost.\n\nTravels with:\nHeboric, Baudin",
      "endPoint": "Meets Kulp, Gesler, Stormy and Truth who are have been sent by Duiker to rescure Heboric."
    },
    {
      "curve": "Escapes on the boat.\n\nTravels with:\nHeboric, Baudin, Kulp, Gesler, Stormy, Truth",
      "endPoint": "The entire ship is dragged into flooded Kurald Ehmurlahn by a a mage who has gone insane from the exposure to Otataral in the mines."
    },
    {
      "curve": "",
      "endPoint": "Finds a new boat in the flooded warren, the Silanda."
    },
    {
      "curve": "Travels through the flooded warren on the Silanda.\n\nTravels with:\nHeboric, Baudin, Kulp, Gesler, Stormy, Truth",
      "endPoint": "Encounters a Soletaken undead dragon. Kulp uses the chance to pull them into a new Warren in the dragon's wake."
    },
    {
      "curve": "",
      "endPoint": "Unable to withstand the fires in the new Warren, she is dragged overboard by Baudin while the Marines stay on board."
    },
    {
      "curve": "Stumbles through the desert.\n\nTravels with:\nHeboric, Baudin, Kulp",
      "endPoint": "Is attacked by Grillen and saved by Baudin and Kulp, who both die in the fight."
    },
    {
      "curve": "Stumbles through the desert.\n\nTravels with:\nHeboric",
      "endPoint": "Meets Leoman and Toblakai at Sha'ik's corpse. They decide to make her the new Sha'ik."
    },
    {
      "curve": "Is taken to the rebel camp at the center of the desert.\n\nTravels with:\nHeboric, Leoman, Toblakai",
      "endPoint": "Serves as the new leader of the rebellion."
    },
    {
      "curve": "Uses the Whirlwind to take her army to Aren to stop Korbolo Dom's slaughter.\n\nTravels with:\nHeboric, Leoman, Toblakai",
      "endPoint": ""
    },
    {
      "curve": "Returns with both armies to the Raraku.\n\nTravels with:\nHeboric, Leoman, Toblakai",
      "endPoint": "Waits in the Raraku for Tavore, to fight her where her strenth is greatest."
    },
    {
      "curve": "",
      "endPoint": "Is killed by Tavore."
    }
  ]
}