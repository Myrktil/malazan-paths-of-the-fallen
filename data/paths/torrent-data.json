  "tooltips": [
    {
      "curve": "Follows Redmask.\n\nTravels with:\nThe Awl",
      "endPoint": "Joins the Barghast camp after the Awl are defeated by the Letherii."
    },
    {
      "curve": "Escapes the angry Barghast camp through a portal by Cafal after speaking against the war with the K'Chain Che'Malle.\n\nTravels with:\nCafal, Setoc",
      "endPoint": "Returns from the portal. Cafal and Setoc decide to return to the Barghast camp."
    },
    {
      "curve": "Rides aimlessly through the Wastelands.\n\nTravels with:\n-",
      "endPoint": "Meets Olar Ethil who joins him."
    },
    {
      "curve": "Finds tracks of a carriage and tries follows them while Olar Ethil is trying to lead him astray.\n\nTravels with:\nOlar Ethil",
      "endPoint": "Meets Telorast and Curdle who decide to join him and Olar Ethil."
    },
    {
      "curve": "Follows the carriage's tracks.\n\nTravels with:\nOlar Ethil, Telorast, Curdle",
      "endPoint": "Catches up to Mappo's escort."
    },
    {
      "curve": "Joins the group.\n\nTravels with:\nThe Trygalle Shareholders, Mappo, Gruntle, Olar Ethil, Setoc, Storii, Stavi, Absi",
      "endPoint": "Decides to stay with Storii, Stavi and Absi when they are forsaken to Olar Ethil by the others."
    },
    {
      "curve": "Follows Olar Ethil.\n\nTravels with:\nOlar Ethil, Storii, Stavi, Absi",
      "endPoint": "Is taken into Tellan by Olar Ethil."
    },
    {
      "curve": "Follows Olar Ethil through Tellan.\n\nTravels with:\nOlar Ethil, Storii, Stavi, Absi",
      "endPoint": "Leaves Tellan with Olar Ethil."
    },
    {
      "curve": "Follows Olar Ethil.\n\nTravels with:\nOlar Ethil, Storii, Stavi, Absi",
      "endPoint": "Appears in Kruppe's Dream Warren where he is given a new bow."
    },
    {
      "curve": "Follows Olar Ethil.\n\nTravels with:\nOlar Ethil, Storii, Stavi, Absi",
      "endPoint": "Stavi, Storii and Absi flee while Olar Ethil is distracted by the T'lan Imass' resurrection."
    },
    {
      "curve": "Leads Olar Ethil away from the children.\n\nTravels with:\nOlar Ethil",
      "endPoint": "Kills the now mortal Olar Ethil but slips into a crack in the ice and dies."
    }
  ]
}