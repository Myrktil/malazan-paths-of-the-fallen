  "tooltips": [
    {
      "curve": "",
      "endPoint": "Protects the Throne of Shadow until Traveler replaces him."
    },
    {
      "curve": "Leaves the island.\n\nTravels with:\nHis fellow Tiste",
      "endPoint": "Is shipwrecked on an Atoll and stays there for a couple months."
    },
    {
      "curve": "Is taken to Malaz by a Jakatan fleet.\n\nTravels with:\nHis fellow Tiste",
      "endPoint": "Stays in Malaz until he joins the Bonehunter fleet."
    },
    {
      "curve": "Stays with the Bonehunters.\n\nTravels with:\nHis fellow Tiste, The Bonehunters",
      "endPoint": "Meets Clip."
    },
    {
      "curve": "Is taken by Clip to Anomander Rake in Coral through Kurald Emurlahn.\n\nTravels with:\nHis fellow Tiste, Clip",
      "endPoint": "Exits the Warren prematurely."
    },
    {
      "curve": "Continues his journey towards Coral.\n\nTravels with:\nHis fellow Tiste, Clip",
      "endPoint": "Stays in a village where his group is attacked by priests of the Crippled God and Clip's soul is stolen by them."
    },
    {
      "curve": "Travels to Bastion to save Clip.\n\nTravels with:\nClip, His fellow Tiste",
      "endPoint": "Meets Kallor who decides to accompany them."
    },
    {
      "curve": "Travels to Bastion to save Clip.\n\nTravels with:\nClip, His fellow Tiste, Kallor",
      "endPoint": "Defeats the priests of the Crippled God and saved Clip."
    },
    {
      "curve": "Continues to travel to Coral.\n\nTravels with:\nClip, His fellow Tiste",
      "endPoint": "Enters Kurald Galain through a portal opened by Clip."
    },
    {
