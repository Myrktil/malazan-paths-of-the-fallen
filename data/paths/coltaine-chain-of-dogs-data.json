  "tooltips": [
    {
      "curve": "Travels with:\nThe Wickans",
      "endPoint": "Arrives in Hissar to take control of the 7th as fist."
    },
    {
      "curve": "Accompanies Sormo E'nath to a dried up oasis where he wants to perform a ritual.\n\nTravels with:\nSormo E'nath, Duiker, Kulp, Bult",
      "endPoint": "Sormo E'nath performs his ritual."
    },
    {
      "curve": "Is pulled into Tellan, where he is attacked by Soletaken/D'ivers.\n\nTravels with:\nSormo E'nath, Duiker, Kulp, Bult",
      "endPoint": "Fights his way out of Tellan."
    },
    {
      "curve": "Returns to Hissar.\n\nTravels with:\nSormo E'nath, Duiker, Kulp, Bult",
      "endPoint": "Hissar is taken by the uprising which has started on the whole continent."
    },
    {
      "curve": "Escorts the fleeing refuges out of Hissar.\n\nTravels with:\nThe Wickans, The 7th",
      "endPoint": "Is attacked by Kamist Reole leading to the battle Bat'rol."
    },
    {
      "curve": "Escorts the fleeing refugees out of Hissar.\n\nTravels with:\nThe Wickans, The 7th",
      "endPoint": "Crosses the Sekala River."
    },
    {
      "curve": "Escorts the fleeing refugees to Ubaryd, which is the nearest safe city.\n\nTravels with:\nThe Wickans, The 7th, Duiker",
      "endPoint": "Decides to take the refugees to Aren since Ubaryd has already fallen to the uprising."
    },
    {
      "curve": "Escorts the fleeing refugees to Aren.\n\nTravels with:\nThe Wickans, The 7th, Duiker",
      "endPoint": "Crosses the Vathar."
    },
    {
      "curve": "Escorts the fleeing refugees to Aren.\n\nTravels with:\nThe Wickans, The 7th, Duiker",
      "endPoint": "Fights the battle of Sanimon. Sends Duiker ahead with the remaining refugees while he aims to buy them time fighting a running battle against Korbolo Dom's army."
    },
    {
      "curve": "Slowly retreats towards Aren while in a constant battle with Korbolo Dom's forces.\n\nTravles with: \nThe Wickans, The 7th",
      "endPoint": "Is finally defeated and killed before of Aren's walls."
    },
    {
      "curve": "His soul is carried by ravens back to the Wickan Plains.",
      "endPoint": ""
    }
  ]
