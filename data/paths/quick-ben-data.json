  "tooltips": [
    {
      "curve": "Serves in the Malazan army.\n\nTravels with:\nThe Bridgeburners",
      "endPoint": "Is present at the siege of pale."
    },
    {
      "curve": "Is carried by the Moranth towards Darujhistan for his next mission.\n\nTravels with:\nThe Bridgeburners, Paran, Apsalar",
      "endPoint": ""
    },
    {
      "curve": "Crosses the lake by boat.\n\nTravels with:\nThe Bridgeburners, Paran, Apsalar",
      "endPoint": "Completes his mission in Darujhistan."
    },
    {
      "curve": "Is on the way to his next mission.\n\nTravels with:\nThe Bridgeburners, Paran",
      "endPoint": ""
    },
    {
      "curve": "Is carried by the Moranth to his next mission.\n\nTravels with:\nThe Bridgeburners, Paran",
      "endPoint": "Enters the Crippled God's Warren after meeting Munug.\n\nTravels with:\n-"
    },
    {
      "curve": "Enters the Crippled God's Warren after meeting Munug.\n\nTravels with:\n-",
      "endPoint": "Escapes into Burn's Flesh and returns to the Bridgeburner's camp."
    },
    {
      "curve": "Moves to Pale by Quorl to meet Kaladan Brood's army to fight against the Pannion Domain.\n\nTravels with:\nThe Bridgeburners, Paran",
      "endPoint": ""
    },
    {
      "curve": "Heads out into Caldan Brood's camp for tactical meetings.\n\nTravels with:\nThe Bridgeburners, Dujek, Paran",
      "endPoint": "Meets with Anomander Rake, Caladan Brood, Dujekt and other important leaders for a tactical meeting."
    },
    {
      "curve": "Marches with the combined main forces to free Capustan from the Pannion Domain.\n\nTravels with:\nDujekt, Caladan Brood and his forces",
      "endPoint": ""
    },
    {
      "curve": "Travels through Hood's Warren to reunite with the Bridgeburners who are trying to gain the White Faced Barghast's support.\n\nTravels with:\n-",
      "endPoint": "Reunites with the Bridgeburners in the Barghast camp."
    },
    {
      "curve": "Moves to Capustan to save the city with the Bridgeburners and Barghast while the slower main armies are still traveling towards Coral.\n\nTravels with:\nThe Bridgeburners, The White Faced Barghast, Paran",
      "endPoint": "Fights in the city to stop the Pannion forces from sieging it and eventually rejoins with Caladan Brood's forces."
    },
    {
      "curve": "Marches towards Settar to retake the city, while Caladan Brood's forces take Lest at the same time.\n\nTravels with:\nThe Bridgeburners, The White Faced Barghast, Kruppe, Paran",
      "endPoint": "Finds Settar entirely void of life."
    },
    {
      "curve": "Quickly moves towards Coral by Quorl to attack it before Caladan's forces arrive there and claim it for the Malazan empire.\n\nTravels with:\nThe Bridgeburners, The White Faced Barghast, Kruppe, Paran",
      "endPoint": "Makes camp in front of Coral."
    },
    {
      "curve": "Enters Coral by Quorl.\n\nTravels with:\nThe Bridgeburners, The White Faced Barghast, Paran",
      "endPoint": "Uses the attack on the city to find the Pannion Seer."
    },
    {
      "curve": "Travels to Morn through a Warren to free the Seer's sister.\n\nTravels with:\nThe Pannion Seer, Paran, Kilava Onass",
      "endPoint": "Frees the Seer's sister."
    },
    {
      "curve": "Takes the Seer and his sister to Burn's flesh to slow the Chained God's corruption.\n\nTravels with:\nParan, The Pannion Seer and his sister",
      "endPoint": ""
    },
    {
      "curve": "Returns to Coral to reunite with the Bridgeburners.\n\nTravels with:\nParan",
      "endPoint": "Reunites with Dujek's Host."
    },
    {
      "curve": "Joins Dujek's Host on their way to Seven Cities.\n\nTravels with:\nDujek",
      "endPoint": ""
    },
    {
      "curve": "Is summoned into the Raraku by Kalam.\n\nTravels with: \n-",
      "endPoint": "Fights during the battle in the oasis and reunites with Kalam and Fiddler."
    },
    {
      "curve": "Chases Leoman and his rebels with the Bonehunters.\n\nTravels with:\nThe Bonehunters",
      "endPoint": "Is asked by Tavore to scout ahead through the Imperial Warren."
    },
    {
      "curve": "Journeys through the Imperial Warren until he encounters the flying fortresses of the K'Chain Naruk.\n\nTravles with:\nStormy, Kalam",
      "endPoint": "Leaves the Imperial Warren to report back to Tavore. Tavore asks him to investigate the flying fortresses."
    },
    {
      "curve": "Tries to enter one of the flying fortresses in the Imperial Warren.\n\nTravels with:\nStormy, Kalam",
      "endPoint": "Returns from the Warren and meets the left behind soldiers who emerged from Y'Gathan."
    },
    {
      "curve": "Catches up to the Bonehunter main forces.\n\nTravels with:\nFiddler's squad, Apsalar, Stormy, Kalam, Faradan Sort, Gessler",
      "endPoint": "Rejoins the Bonehunters."
    },
    {
      "curve": "Sails with the Bonehunters to Malaz.\n\nTravels with:\nThe Bonehunters, Apsalar, Kalam",
      "endPoint": "Meets the Verender who join the Bonehunters."
    },
    {
      "curve": "Is teleported through the Warren of Togg and Fanderay by the Verender.\n\nTravels with:\nThe Bonehunters, The Verender, Apsalar, Kalam",
      "endPoint": "Leaves the Warren."
    },
    {
      "curve": "Follows the Bonehunters to Malaz.\n\nTravels with:\nThe Bonehunters, The Verender, Apsalar, Kalam",
      "endPoint": "Meets Shadowthrone."
    },
    {
      "curve": "Is teleported by Shadowthrone.\n\nTravels with:\n-",
      "endPoint": "Defends the First Throne against Icarium."
    },
    {
      "curve": "Is teleported into the Warren of Shadow by Cotillion to recuperate after the fight.\n\nTravels with:\nTrull, Onogros",
      "endPoint": "Is given access to one of the gates of Shadow by Cotillion to leave the Warren."
    },
    {
      "curve": "Crosses a sea in the Warren of Shadow to get to the gate.\n\nTravels with:\nTrull, Onrack",
      "endPoint": "Is attacked by an N'purel and opens a gate to Tellan to flee."
    },
    {
      "curve": "Wanders through Tellan.\n\nTravels with:\nOnrack, Trull",
      "endPoint": "Reaches and defends the Refugium."
    },
    {
      "curve": "Travels through the Warrens to Letheras to meet with the Bonehunters.\n\nTravels with:\nTrull, Seren, Hedge",
      "endPoint": "Rejoins the Bonehunters."
    },
    {
      "curve": "Marches towards Kolanse.\n\nTravels with:\nThe Bonehunters, Brys and his troops",
      "endPoint": "Disappears during the battle against the K'Chain Nah'ruk."
    },
    {
      "curve": "Travels through the Warrens.\n\nTravels with:\n-",
      "endPoint": "Picks up Kalam from the Deadhouse."
    },
    {
      "curve": "Is teleported by Shadowthrone by Paran's wish.\n\nTravels with:\nKalam",
      "endPoint": "Is tasked by Paran to kill the Assail guarding the pass."
    },
    {
      "curve": "Teleports Kalam behind enemy lines.\n\nTravels with:\nKalam",
      "endPoint": "Kills the Assail."
    },
    {
      "curve": "Travels with Paran's troops.\n\nTravels with:\nKalam, Paran's troops",
      "endPoint": "Is tasked by Paran to ride ahead to help the Bonehunters against the Assail until he arrives."
    },
    {
      "curve": "Rides ahead to help Tavore and the Bonehunters.\n\nTravels with:\nKalam",
      "endPoint": "Decides to ride to the Otataral sword and the ritual instead of Tavore."
    },
    {
      "curve": "Rides to the Otataral sword's ritual.\n\nTravels with:\nKalam",
      "endPoint": "Arrives at the ritual site and helps to defend it against the Assail onslaught."
    },
    {
      "curve": "",
      "endPoint": "Attends Gesler and Stormie's funeral."
    }
  ]
