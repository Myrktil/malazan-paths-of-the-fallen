  "tooltips": [
    {
      "curve": "",
      "endPoint": "Is posessed by Cotillion."
    },
    {
      "curve": "Travels with:\n-",
      "endPoint": "Joins the army and is assigned to the Bridgeburners."
    },
    {
      "curve": "Is on her way to join the Bridgeburners.\n\nTravels with:\n-",
      "endPoint": "Joins the Bridgeburners."
    },
    {
      "curve": "Serves in the Malazan army.\n\nTravels with:\nThe Bridgeburners",
      "endPoint": "Is present at the siege of pale."
    },
    {
      "curve": "Is carried by the Moranth towards Darujhistan for her next mission with the Bridgeburners.\n\nTravels with:\nThe Bridgeburners",
      "endPoint": ""
    },
    {
      "curve": "Crosses the lake by boat.\n\nTravels with:\nThe Bridgeburners",
      "endPoint": "Searches for and finds Crokus."
    },
    {
      "curve": "Follows Crokus in an attempt to kill him.\n\nTravels with:\n-",
      "endPoint": ""
    },
    {
      "curve": "Used the warren of Shadow to remain undetected by Crokus.\n\nTravels with:\n-",
      "endPoint": "Witnesses Crokus and his group being attacked by Lorn but before she can kill him, Anomander Rake forces Cotillion to leave her body. "
    },
    {
      "curve": "Still recovering from being posessed she is taken back to Darujhistan by Corkus to get help from Mammot.\n\nTravels with:\nCrokus",
      "endPoint": "Get's involved in the events surrounding Lady Simtals Fete."
    },
    {
      "curve": "Is escorted back to Itko Kan.\n\nTravels with:\nFiddler, Kalam, Crokus",
      "endPoint": "Instead of going to Quon Tali directly, Fiddler and Kalam decide to use the Azath house Tremorlor to get into Malaz unseen which would help them with their secret goal of killing empress Laseen."
    },
    {
      "curve": "Follows Fiddler and Kalam who try to find Tremorlor.\n\nTravels with:\nFiddler, Kalam, Crokus",
      "endPoint": "Kalam splits from the group leaving her alone with Crokus and Fiddler."
    },
    {
      "curve": "Follows Fiddler who continues to search for Tremorlor under the guise of an outcast Gral who protects Crokus and her who pretend to be a newly wed couple.\n\nTravels with:\nFiddler, Crokus",
      "endPoint": "She thinks they are being pursued. Fiddler thinks it's the Gral who are searching for him due to his disguise."
    },
    {
      "curve": "Head's into the whirlwind to escape the Gral.\n\nTravels with:\nFiddler, Crokus",
      "endPoint": "Meets Mappo and Icarium who were send to find her, Crokus and Fiddler by Iskaral Pust."
    },
    {
      "curve": "Is taken by to Tesem by Mappo and Icarium.\n\nTravels with:\nFiddler, Crokus, Mappo, Icarium",
      "endPoint": "Stays in Tesem for a while and meets her father."
    },
    {
      "curve": "Follows her father who has ventured into the whirlwind.\n\nTravels with:\n-",
      "endPoint": "Enters the Azath Warren of Tremorlor."
    },
    {
      "curve": "Travels through the Azath's paths.\n\nTravels with:\nFiddler, Crokus",
      "endPoint": "Meets Shadowthrone in the Azath house."
    },
    {
      "curve": "Is teleported back to her home village by Shadowthrone using the Warren of Shadow.\n\nTravels with:\nCrokus",
      "endPoint": "Takes on a mission for Cotillion."
    },
    {
      "curve": "Sails to Drift Avalii on a mission for Cotillion.\n\nTravels with:\nCrokus",
      "endPoint": "Defends the Throne of Shadow from the Tiste Edur."
    },
    {
      "curve": "Is teleported away by Cotillion after completing her mission.\n\nTravels with:\nCrokus",
      "endPoint": "Stays in Tesem until she takes on another mission for Cotillion."
    },
    {
      "curve": "Heads out to kill a number of people for Cotillion.\n\nTravels with:\n-",
      "endPoint": "Assasinates her first target."
    },
    {
      "curve": "Heads out to the next target.\n\nTravels with:\nTelorast, Curdle",
      "endPoint": "Enters Kurlad Emurlahn to cross the ocean."
    },
    {
      "curve": "Travels through Kurald Emurlahn to cross the ocean.",
      "endPoint": "Is pulled onto his boat by Paran."
    },
    {
      "curve": "Travels with Paran for a while.\n\nTravels with:\nParan, Telorast, Curdle",
      "endPoint": "Parts ways with Paran."
    },
    {
      "curve": "Travels to Y'Gathan due to a bad feeling.\n\nTravles with:\nTelorast, Curdle",
      "endPoint": "Enters Kurald Emurlahn."
    },
    {
      "curve": "Travels through Emurlahn to speed up her journey.\n\nTravels with:\nTelorast, Curdle",
      "endPoint": "Meets the Bonehunters who survived beneath Y'Gathan and joins them."
    },
    {
      "curve": "Follows the left behind Bonehunters.\n\nTravels with:\nFiddler's squad, Gesler, Quick Ben, Kalam, Faradan Sort, Stormy",
      "endPoint": ""
    },
    {
      "curve": "Travels through the warren of Shadow to help Quick Ben during his fight against Poliel.\n\nTravels with:\n-",
      "endPoint": "Saves Quick Ben from the Hounds of Shadow."
    },
    {
      "curve": "Returns to the Bonehunter squad through Kurald Emurlahn.\n\nTravels with:\n-",
      "endPoint": "Rejoins the Bonehunter squad."
    },
    {
      "curve": "Travels with the left behind Bonehunters.\n\nTravels with:\nFiddler's squad, Gesler, Quick Ben, Kalam, Faradan Sort, Stormy",
      "endPoint": "Reaches the main Bonehunter forces and is allowed to accompany them by Tavore."
    },
    {
      "curve": "Follows the Bonehunters to Malaz.\n\nTravels with:\nThe Bonehunters",
      "endPoint": "Meets the Verender who join the Bonehunters."
    },
    {
      "curve": "Is teleported through the Warren of Togg and Fanderay by the Verender.\n\nTravels with:\nThe Bonehunters, The Verender",
      "endPoint": "Leaves the Warren."
    },
    {
      "curve": "Follows the Bonehunters to Malaz.\n\nTravels with:\nThe Bonehunters, The Verender",
      "endPoint": "Stays in the Malaz while the Bonehunters leave."
    },
    {
      "curve": "",
      "endPoint": "Meets Crokus."
    }
  ]
}