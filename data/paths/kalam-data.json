  "tooltips": [
    {
      "curve": "Serves in the Malazan army.\n\nTravels with:\nThe Bridgeburners",
      "endPoint": "Is present at the siege of pale."
    },
    {
      "curve": "Is carried by the Moranth towards Darujhistan for his next mission with the Bridgeburners.\n\nTravels with:\nThe Bridgeburners, Paran, Apsalar",
      "endPoint": ""
    },
    {
      "curve": "Crosses the lake by boat.\n\nTravels with:\nThe Bridgeburners, Paran, Apsalar",
      "endPoint": "Completes his mission in Darujhistan."
    },
    {
      "curve": "Escorts Apsalar back to Itko Kan.\n\nTravels with:\nFiddler, Crokus, Apsalar",
      "endPoint": "Instead of going to Quon Tali directly, he and Fiddler decide to use the Azath house Tremorlor to get into Malaz unseen which would help them with their secret goal of killing empress Laseen."
    },
    {
      "curve": "Travels to Seven Cities to find Tremorlor.\n\nTravels with:\nFiddler, Crokus, Apsalar",
      "endPoint": "Splits from the group to meet with Mebra. He finds the book of Sha'ik."
    },
    {
      "curve": "Delivers book of Dryjhna to Sha'ik.\n\nTravels with:\n-",
      "endPoint": "Meets Sha'ik and gives her the book."
    },
    {
      "curve": "Leaves the Raraku.\n\nTravels with:\n-",
      "endPoint": "Meets Keneb and Minala and decides to journey with them towards Aren."
    },
    {
      "curve": "Travels towards Aren with Keneb and Minala.\n\nTravels with:\nKeneb, Minala",
      "endPoint": "Runs into Korbolo Dom's camp and can't proceed so he enters the Imperial Warren."
    },
    {
      "curve": "Travles through the Imperial Warren.\n\nTravels with:\nKeneb, Minala",
      "endPoint": "Get's on the ship Ragstopper to travel to Unta."
    },
    {
      "curve": "Travels on the Ragstopper.\n\nTravels with:\n-",
      "endPoint": "Is blown off course by a storm."
    },
    {
      "curve": "Needs to make a stop in Malaz after the storm.\n\nTravels with:\n-",
      "endPoint": "Is stabbed and thrown overboard by Pearl."
    },
    {
      "curve": "Swims to the shore.\n\nTravels with:\n-",
      "endPoint": "Fights his way through the claw's hands trying to stop him until he and Minala, who followed and rescured him, reach Laseen in Mock's Hold. \nHe decides to spare Laseen and on his way out of Mock's Hold they are dragged into the Shadow Warren by Shadowthrone. \nHe accepts Shadowthrone's offer to stay with Minala in the Shadow Warren."
    },
    {
      "curve": "Travels through the Shadow Warren.\n\nTravels with:\nMinala",
      "endPoint": "Protects the raises the children Apt rescured with Minala."
    },
    {
      "curve": "Flees from the burden of having a wife and children by taking a mission from Cotillion to find who is threatening their hold on the Throne of Shadow.\n\nTravels with: \n-",
      "endPoint": "Is attacked by a demon and saved by Iskaral Pust."
    },
    {
      "curve": "Is taken to Tessem.\n\nTravels with:\nIskaral Pust",
      "endPoint": ""
    },
    {
      "curve": "Travels into the Rebel's oasis to complete his mission for Cotillion.",
      "endPoint": "Completes his mission and reuintes with Fiddler and Quick Ben."
    },
    {
      "curve": "Chases Leoman and his rebels with the Bonehunters.\n\nTravels with:\nThe Bonehunters",
      "endPoint": "Is asked by Tavore to scout ahead through the Imperial Warren."
    },
    {
      "curve": "Journes through the Imperial Warren until he encounters the flying fortresses of the K'Chain Naruk.\n\nTravles with:\nQuick Ben, Stormy",
      "endPoint": "Is taken out of the Warren by Quick Ben to report back to Tavore. Tavore asks them to investigate the flying fortresses."
    },
    {
      "curve": "Tries to enter one of the flying fortresses in the Imperial Warren.\n\nTravels with:\nQuick Ben, Stormy",
      "endPoint": "Returns from the Warren and meets the left behind soldiers who emerged from Y'Gathan."
    },
    {
      "curve": "Catches up to the Bonehunter main forces.\n\nTravels with:\nFiddler's squad, Apsalar, Quick Ben, Stormy, Faradan Sort, Gessler",
      "endPoint": "Rejoins the Bonehunters."
    },
    {
      "curve": "Sails with the Bonehunters to Malaz.\n\nTravels with:\nThe Bonehunters",
      "endPoint": "Meets the Verender who join the Bonehunters."
    },
    {
      "curve": "Is teleported through the Warren of Togg and Fanderay by the Verender.\n\nTravels with:\nThe Bonehunters, The Verender",
      "endPoint": "Leaves the Warren."
    },
    {
      "curve": "Follows the Bonehunters to Malaz.\n\nTravels with:\nThe Bonehunters, The Verender",
      "endPoint": "Is nearly killed by Pearl and rescued into the Deadhouse by Shadowthrone."
    },
    {
      "curve": "Is teleported by Shadowthrone by Paran's wish.\n\nTravels with:\nQuick Ben",
      "endPoint": "Is tasked by Paran to kill the Assail guarding the pass."
    },
    {
      "curve": "Is teleported behind enemy lines by Quick Ben.\n\nTravels with:\nQuick Ben",
      "endPoint": "Kills the Assail."
    },
    {
      "curve": "Travels with Paran's troops.\n\nTravels with:\nQuick Ben, Paran's troops",
      "endPoint": "Is tasked by Paran to ride ahead to help the Bonehunters against the Assail until he arrives."
    },
    {
      "curve": "Rides ahead to help Tavore and the Bonehunters.\n\nTravels with:\nQuick Ben",
      "endPoint": "Follows Quick Ben when he decides to ride to the Otataral sword and the ritual instead of Tavore."
    },
    {
      "curve": "Rides to the Otataral sword's ritual.\n\nTravels with:\nQuick Ben",
      "endPoint": "Arrives at the ritual site and helps to defend it against the Assail onslaught."
    },
    {
      "curve": "",
      "endPoint": "Attends Gesler and Stormie's funeral."
    }
  ]
}