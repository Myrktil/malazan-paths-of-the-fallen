  "tooltips": [
    {
      "curve": "Travels through the Imperial Warren.\n\nTravels with:\n-",
      "endPoint": "Leaves the Imperial Warren when he notices Kalam opening a portal to it."
    },
    {
      "curve": "Travels with:\n-",
      "endPoint": "Meets Lostara Yil who is pursuing Kalam and re-enters the Imperial Warren with her."
    },
    {
      "curve": "Pursues Kalam in the Imperial Warren.\n\nTravels with:\nLostara Yil",
      "endPoint": "Temporarily leaves the Imperial Warren to secretly help the 7th army in their fight."
    },
    {
      "curve": "Continues to pursue Kalam through the Imperial Warren.\n\nTravels with:\nLostara Yil",
      "endPoint": "Arrives before Kalam and set's up a trap by disguising himself as a passenger on the Ragstopper, the ship Kalam is planning to take to get to Unta."
    },
    {
      "curve": "Travels on the Ragstopper.\n\nTravels with:\nKalam",
      "endPoint": "Is blown off course by a storm."
    },
    {
      "curve": "Needs to make a stop in Malaz after the storm.\n\nTravels with:\nKalam",
      "endPoint": "Reveals his true identity to Kalam, stabs him and throws him overboard to weaken him and allowing the claw's hands to hunt him."
    },
    {
      "curve": "Uses the Imperial Warren to get into the city.\n\nTravels with:\n-",
      "endPoint": "Appears in Smiley's Bar."
    },
    {
      "curve": "",
      "endPoint": "Accepts Tavore's request to search for Felisin."
    },
    {
      "curve": "Travels through the Imperial Warren in search for Felisin.\n\nTravels with: \nLostara Yil",
      "endPoint": "Leaves the Imperial Warren to follow Felisin's tracks through the Raraku."
    },
    {
      "curve": "Follows Felisin's tracks.\n\nTravels with:\nLostara Yil",
      "endPoint": "Visits Sha'ik's place of death and figures out that Felisin is the new Sha'ik."
    },
    {
      "curve": "Tries to stop Tavore from killing Felisin.\n\nTravels with:\nLostara Yil",
      "endPoint": "Arrives after the battle in the oasis has ended and takes Felisin's body away before Tavore can see her."
    },
    {
      "curve": "Stays with Tavore.\n\nTravels with:\nThe Bonehunters",
      "endPoint": ""
    },
    {
      "curve": "",
      "endPoint": "Is killed by Apsalar."
    }
  ]
}