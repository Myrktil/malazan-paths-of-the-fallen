  "tooltips": [
    {
      "curve": "",
      "endPoint": "Lives as a slave to the Sengars."
    },
    {
      "curve": "Travels with Rhulad as his personal slave during the invasion of Letheras.\n\nTravels with:\nRhulad",
      "endPoint": "They reunite with the Edur land troops."
    },
    {
      "curve": "Follows Rhulad who investigates rumors of a demon summoned by the Letherii.\n\nTravels with:\nRhulad, Fear, Trull",
      "endPoint": "The demon turns out to be the Assail Serenity, who is defeated by Trull."
    },
    {
      "curve": "Follows Rhulad who returns to is forces.\n\nTravels with:\nFear, Rhulad, Trull",
      "endPoint": "Rejoins the Edur forces."
    },
    {
      "curve": "Follows Rhulad on the final march towards Letheras.\n\nTravels with:\nRhulad, Fear, Trull, Binadas",
      "endPoint": "Is overtaken by the Wyval within him and nearly dies. Is saved by Kettle."
    },
    {
      "curve": "Follows Fear on his search for Silchas Ruin to escape from the Letherii and Edur hunting him.\n\nTravels with:\nSeren Pedac, Fear, Kettle, Scabandari",
      "endPoint": "Meets Clip."
    },
    {
      "curve": "Is teleported through Kurald Galain by Clip.\n\nTravels with:\nSeren Pedac, Fear, Kettle, Silchas Ruin, Clip",
      "endPoint": "Waits for Fear to convince the Andii elder's to help him."
    },
    {
      "curve": "Follows Clip who leads him to Scabandari.\n\nTravels with:\nSeren Pedac, Fear, Kettle, Silchas Ruin, Clip",
      "endPoint": "Arrives at the Refugium and stays there with Rud Elalle."
    }
  ]
}