  "tooltips": [
    {
      "curve": "Travels to the Edur main village as escort to the merchant Buruk.\n\nTravels with:\nBuruk",
      "endPoint": ""
    },
    {
      "curve": "Escorts Buruk back.\n\nTravels with:\nBuruk",
      "endPoint": "Get's caught up in the Edur's attack on the city. Is saved by Iron Bars and his squad into Kurald Galain."
    },
    {
      "curve": "Travels through Kurald Galain under the guidance of Sandalath.\n\nTravels with:\nIron Bars and his squad, Sandalath",
      "endPoint": "Leaves Kurald Galain."
    },
    {
      "curve": "Returns to Lether.\n\nTravels with:\nIron Bars and his squad",
      "endPoint": "Hides in her house during the Edur's overtaking of the city."
    },
    {
      "curve": "Escorts Fear, Kettle, Udinaas and Silchas Ruin out of Lethereas and stays with the group.\n\nTravels with:\n Fear, Kettle, Udinaas, Silchas Ruin",
      "endPoint": "Meets Clip."
    },
    {
      "curve": "Is teleported through Kurald Galain by Clip.\n\nTravels with:\nUdinaas, Fear, Kettle, Silchas Ruin, Clip",
      "endPoint": "Waits for Fear to convince the Andii elder's to help him."
    },
    {
      "curve": "Follows Clip who leads her to Scabandari.\n\nTravels with:\nUdinaas, Fear, Kettle, Silchas Ruin, Clip",
      "endPoint": "Arrives at the Refugium and is reunited with Trull."
    },
    {
      "curve": "Is teleported back to Letheras by Quick Ben.\n\nTravels with:\nTrull, Quick Ben, Hedge",
      "endPoint": "Stays in Letheras."
    }
  ]
